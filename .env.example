TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
ANTHROPIC_API_KEY=

# Optional: pin the OAuth callback port so live TrueLayer apps can register
# a stable http://localhost:<PORT>/callback redirect URI. If unset, Ferret
# picks a random free port in 8000–8999 per run (fine for dev/sandbox).
FERRET_OAUTH_PORT=
